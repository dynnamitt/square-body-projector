<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>__TITLE__</title>
  <style>
    html, body { margin: 0; height: 100%; background: #111118; color: #dde; font: 13px/1.4 system-ui, sans-serif; overflow: hidden; }
    body { display: grid; grid-template-columns: 1fr 1fr; }
    .pane { padding: 16px; box-sizing: border-box; height: 100vh; }
    .pane + .pane { border-left: 1px solid #333; }
    #svg { width: 100%; height: 100%; object-fit: contain; background: #fff; display: block; }
    #cv  { display: block; width: 100%; height: 100%; }
    #hud { position: fixed; top: 8px; left: 10px; opacity: .75; user-select: none; display: flex; gap: .75em; align-items: center; }
    #hud .meta { pointer-events: none; opacity: .7; }
    #pick { background: #1c1c26; color: #dde; border: 1px solid #333; padding: 3px 6px; font: inherit; }
    #err { position: fixed; top: 0; left: 0; right: 0; padding: 1em; background: #511; color: #fcc; white-space: pre-wrap; display: none; }
  </style>
  <script type="importmap">
  {
    "imports": {
      "three": "https://esm.sh/three@0.160.0",
      "three/addons/": "https://esm.sh/three@0.160.0/examples/jsm/",
      "fast-xml-parser": "https://esm.sh/fast-xml-parser@4.3.2"
    }
  }
  </script>
</head>
<body>
  <div class="pane"><img id="svg" alt="source"></div>
  <div class="pane"><canvas id="cv"></canvas></div>
  <div id="hud">
    <select id="pick">__SVG_OPTIONS__</select>
    <span class="meta">__TITLE__ &middot; built __BUILT__ &middot; drag to orbit, scroll to zoom</span>
  </div>
  <pre id="err"></pre>
  <script type="module" src="app.js"></script>
</body>
</html>
