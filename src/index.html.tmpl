<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>__TITLE__</title>
  <style>
    :root {
      --bg: #111118;
      --panel: #16161f;
      --border: #2a2a3a;
      --fg: #dde;
      --muted: #8a8a99;
      --accent: #5b7fff;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; height: 100%; }
    body {
      background: var(--bg); color: var(--fg);
      font: 13px/1.45 system-ui, -apple-system, Segoe UI, sans-serif;
      display: grid; grid-template-rows: auto 1fr; overflow: hidden;
    }
    #hud {
      display: flex; flex-wrap: wrap; align-items: center;
      gap: .5em 1.25em; padding: .6em 1em;
      background: var(--panel); border-bottom: 1px solid var(--border);
    }
    #hud .controls { display: flex; flex-wrap: wrap; gap: .5em .75em; align-items: center; }
    #hud .meta { color: var(--muted); margin-left: auto; font-size: 12px; }
    #hud label { display: inline-flex; gap: .35em; align-items: center; color: var(--muted); }
    #hud .meta a { color: var(--fg); text-decoration: none; border-bottom: 1px dotted var(--border); }
    #hud .meta a:hover { color: var(--accent); border-bottom-color: var(--accent); }
    #pick, #bg, #color, #zstep {
      background: #1c1c26; color: var(--fg);
      border: 1px solid var(--border); border-radius: 4px;
      padding: 4px 8px; font: inherit;
    }
    #pick:focus, #bg:focus, #color:focus, #zstep:focus { outline: none; border-color: var(--accent); }
    #zstep { width: 5em; }
    main {
      display: grid; grid-template-columns: 1fr 1fr;
      min-height: 0; overflow: hidden;
    }
    .pane { padding: 16px; overflow: hidden; min-height: 0; min-width: 0; }
    .pane + .pane { border-left: 1px solid var(--border); }
    #svg { width: 100%; height: 100%; object-fit: contain; display: block; }
    #cv  { width: 100%; height: 100%; display: block; }
    #err {
      position: fixed; top: 0; left: 0; right: 0; z-index: 10;
      padding: 1em; background: #511; color: #fcc;
      white-space: pre-wrap; display: none;
    }
    @media (max-width: 720px) {
      main { grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; }
      .pane + .pane { border-left: 0; border-top: 1px solid var(--border); }
      #hud .meta { margin-left: 0; order: 99; width: 100%; }
    }
  </style>
  <script type="importmap">
  {
    "imports": {
      "three": "https://esm.sh/three@0.160.0",
      "three/addons/": "https://esm.sh/three@0.160.0/examples/jsm/",
      "fast-xml-parser": "https://esm.sh/fast-xml-parser@4.3.2"
    }
  }
  </script>
</head>
<body>
  <header id="hud">
    <div class="controls">
      <select id="pick">__SVG_OPTIONS__</select>
      <select id="color"></select>
      <select id="bg">
        <option value="#111118">dark</option>
        <option value="white">white</option>
        <option value="silver">silver</option>
        <option value="slategray">slategray</option>
        <option value="steelblue" selected>steelblue</option>
        <option value="darkslateblue">darkslateblue</option>
      </select>
      <label>z-step <input id="zstep" type="number" step="0.1" value="0.1"></label>
    </div>
    <div class="meta"><a href="__REPO_URL__" target="_blank" rel="noopener">__TITLE__</a> &middot; built __BUILT__ &middot; drag to orbit, scroll to zoom</div>
  </header>
  <main>
    <div class="pane"><img id="svg" alt="source"></div>
    <div class="pane"><canvas id="cv"></canvas></div>
  </main>
  <pre id="err"></pre>
  <script type="module" src="app.js"></script>
</body>
</html>
